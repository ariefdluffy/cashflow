# Cash Flow Dashboard - Environment Variables

# Server
PORT=3000
ORIGIN=http://localhost:3000

# --- Opsi 1: Path ke file JSON kredensial (paling reliable) ---
# Download dari Google Cloud Console > Service Account > Keys > JSON
# GOOGLE_CREDENTIALS_PATH=/cashflow-dashboard-499013-387e37335258.json

# --- Opsi 2: Email + Private Key langsung ---
# GOOGLE_SERVICE_ACCOUNT_EMAIL=cashflow-sheets@xxx.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# Google Sheet ID (opsional, punya default dari PRD)
SHEET_ID=1e9zWYNdSXFpDapCj20hO6I_1EAIFlND-s53ywRtOxZY

# URL endpoint webhook utk Google Drive push notifications
# WAJIB: URL publik HTTPS (production) atau pakai ngrok/tunnel (development)
# Contoh production: https://cashflow.domain.com/api/webhook/drive
# Contoh dev via ngrok:  https://abc123.ngrok.io/api/webhook/drive
# Biarkan kosong kalo mau fallback ke polling (30 detik)
# GOOGLE_DRIVE_WEBHOOK_URL=https://example.com/api/webhook/drive

# Node environment
NODE_ENV=development
